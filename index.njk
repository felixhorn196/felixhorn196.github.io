---
permalink: /
title: Home
---
{% extends "base.njk" %}

{% block content %}
<p>Welcome! Explore my stories, art, videos, theories, and more.</p>
<h2>Latest Stories</h2>
<div class="grid">
  {% for post in collections.stories | reverse | slice(0,3) %}
  <article>
    <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <p>{{ post.templateContent | striptags | truncate(80) }}</p>
  </article>
  {% endfor %}
</div>
<p><a href="/stories/">All Stories →</a></p>
{% endblock %}