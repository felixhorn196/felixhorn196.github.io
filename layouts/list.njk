{% extends "base.njk" %}

{% block content %}
<h2>{{ title }}</h2>
<div class="grid">
  {% for post in collections[section] %}
  <article>
    {% if post.data.thumb %}<img src="{{ post.data.thumb }}" alt="{{ post.data.title }}">{% endif %}
    <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <p>{{ post.data.description or post.templateContent | striptags | truncate(100) }}</p>
    <a href="{{ post.url }}">Read More</a>
  </article>
  {% endfor %}
</div>
{% endblock %}